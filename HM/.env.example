# Copy this to .env and fill in values

# Django Core
SECRET_KEY=your-super-secret-key-here-generate-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.railway.app,localhost,127.0.0.1

# Database (Railway/Render auto-sets DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Email (SendGrid)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourhospital.com

# Hospital Info
HOSPITAL_NAME=MediCare Hospital
HOSPITAL_ADDRESS=123 Health Street, Medical City
HOSPITAL_PHONE=+1-234-567-8900
HOSPITAL_EMAIL=info@medicare.com
